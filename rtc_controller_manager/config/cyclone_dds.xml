<?xml version="1.0" encoding="UTF-8"?>
<!--
  cyclone_dds.xml — CycloneDDS performance-optimized configuration
  for RT Controller Manager (500Hz control loop).

  Optimizations:
    1. Multicast enabled — supports multi-host discovery across network
    2. Discovery tuning — reduced lease/heartbeat for faster failover
    3. Nack delay minimized — faster reliable data delivery

  Thread affinity: handled by taskset in robot.launch.py (CycloneDDS 0.11+
  removed <Internal><Threads> XML support).

  Loaded automatically via CYCLONEDDS_URI env var set in launch files.
  Reference: https://cyclonedds.io/docs/cyclonedds/latest/config/index.html
-->
<CycloneDDS>
  <Domain>
    <General>
      <Interfaces>
        <!-- Auto-detect NIC; multicast enabled for multi-host discovery
             (control PC ↔ monitoring PC on same subnet). -->
        <NetworkInterface autodetermine="true" multicast="true"/>
      </Interfaces>

      <!-- Allow multicast for SPDP discovery so nodes on different hosts
           can find each other. Data delivery uses unicast. -->
      <AllowMulticast>spdp</AllowMulticast>

      <!-- Max message size aligned with typical DDS RTPS fragment size.
           Default 65500 is fine for our small-payload topics. -->
      <MaxMessageSize>65500 B</MaxMessageSize>
      <FragmentSize>4000 B</FragmentSize>
    </General>

    <!-- ── Discovery tuning ─────────────────────────────────────────── -->
    <Discovery>
      <!-- Shorter participant lease: detect dead participants in 5s
           instead of default 10s. Reduces stale reader/writer entries. -->
      <LeaseDuration>5s</LeaseDuration>

      <!-- Faster SPDP announcements at startup for quicker discovery,
           then back off. Default is 30s which is too slow for bringup. -->
      <SPDPInterval>1s</SPDPInterval>
    </Discovery>

    <!-- ── Reliability / latency tuning ─────────────────────────────── -->
    <Internal>
      <!-- NACK response delay: minimize for faster retransmission.
           Default 100ms is far too high for RT control. -->
      <NackDelay>10 ms</NackDelay>

      <!-- Pre-emptive NACK delay: respond quickly to gaps. -->
      <PreEmptiveAckDelay>10 ms</PreEmptiveAckDelay>

      <!-- Heartbeat interval for reliable writers.
           Lower = faster loss detection, slightly more overhead.
           100ms is good balance for 500Hz publish. -->
      <HeartbeatInterval>100 ms</HeartbeatInterval>

      <!-- Squash multiple writes into fewer network packets when
           publishing bursts (e.g., 6-DOF commands + state). -->
      <MaxQueuedRexmitMessages>256</MaxQueuedRexmitMessages>

      <!-- Deliver data synchronously when possible, reducing
           thread wake-up latency for subscriber callbacks. -->
      <SynchronousDeliveryLatencyBound>inf</SynchronousDeliveryLatencyBound>
    </Internal>

    <Tracing>
      <Verbosity>warning</Verbosity>
    </Tracing>
  </Domain>
</CycloneDDS>
