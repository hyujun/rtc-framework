<!-- file: trees/hand_motions.xml -->
<!-- UR5e + 10-DoF Hand Demo: Opposition + FlexExtend Wave (with articulation) -->
<!-- BehaviorTree.CPP v4 syntax -->
<!-- Trajectory speed is controlled via SetGains hand_trajectory_speed.       -->
<!-- Node completion is based on RT controller trajectory duration estimation. -->

<root BTCPP_format="4" main_tree_to_execute="FullDemo">

  <!-- ================================================================== -->
  <!-- SingleOpposition: Single finger opposition motion                   -->
  <!--   Moves thumb + target finger into opposition pose simultaneously.  -->
  <!--   Non-target fingers are automatically reset to home by             -->
  <!--   MoveOpposition internally.                                        -->
  <!--   If use_home_return is true, returns all fingers to home pose      -->
  <!--   after the opposition motion completes.                            -->
  <!-- ================================================================== -->
  <BehaviorTree ID="SingleOpposition">
    <Sequence>
      <MoveOpposition thumb_pose="{op_thumb_pose}"
                      target_finger="{op_target_finger}"
                      target_pose="{op_target_pose}"
                      hand_trajectory_speed="{hand_speed}"
                      hand_max_traj_velocity="{hand_max_vel}"/>

      <!-- use_home_return == true 일 때만 home 포즈로 복귀 -->
      <Fallback>
        <Precondition if="use_home_return == false" else="FAILURE">
          <AlwaysSuccess/>
        </Precondition>
        <SetHandPose pose="home"
                     hand_trajectory_speed="{hand_speed}"
                     hand_max_traj_velocity="{hand_max_vel}"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- OppositionCycle: One full opposition cycle (index -> middle -> ring) -->
  <!--   Sequentially opposes the thumb against each finger in order.      -->
  <!--   Each SubTree inherits hand_speed, hand_max_vel, and               -->
  <!--   use_home_return from the parent Blackboard.                       -->
  <!-- ================================================================== -->
  <BehaviorTree ID="OppositionCycle">
    <Sequence>
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_index_oppose"
               op_target_finger="index"
               op_target_pose="index_oppose"
               hand_speed="{hand_speed}"
               hand_max_vel="{hand_max_vel}"
               use_home_return="{use_home_return}"/>
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_middle_oppose"
               op_target_finger="middle"
               op_target_pose="middle_oppose"
               hand_speed="{hand_speed}"
               hand_max_vel="{hand_max_vel}"
               use_home_return="{use_home_return}"/>
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_ring_oppose"
               op_target_finger="ring"
               op_target_pose="ring_oppose"
               hand_speed="{hand_speed}"
               hand_max_vel="{hand_max_vel}"
               use_home_return="{use_home_return}"/>
    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- OppositionDemo: Three-phase opposition with acceleration ramp       -->
  <!--   Phase 1: Slow cycle with home return between each opposition.     -->
  <!--   Phase 2: Accelerating cycles without home return (speed ramps     -->
  <!--            up by x1.43 per cycle, capped at hand_max_speed).        -->
  <!--   Phase 3: Decelerating cycles with home return restored (speed     -->
  <!--            ramps down by x0.7 per cycle, floored at init speed).    -->
  <!--   All speed changes are applied via SetGains hand_trajectory_speed  -->
  <!--   to stay synchronized with the RT controller.                      -->
  <!-- ================================================================== -->
  <BehaviorTree ID="OppositionDemo">
    <Sequence>

      <!-- 공통 변수 설정 (여기서 한 번만 변경하면 전체 적용) -->
      <Script code="num_cycles := 4; hand_init_speed := 0.7854; hand_max_speed := 3.1415; hand_max_vel := 6.2832"/>
      <Script code="hand_speed := hand_init_speed; use_home_return := true"/>

      <!-- ── Phase 1: 느리게, home 경유 (1회 순회) ── -->
      <SetGains hand_trajectory_speed="{hand_init_speed}"/>
      <SubTree ID="OppositionCycle"
               hand_speed="{hand_speed}"
               hand_max_vel="{hand_max_vel}"
               use_home_return="{use_home_return}"/>

      <!-- ── Phase 2: 가속, home 생략 ── -->
      <Script code="use_home_return := false"/>
      <Repeat num_cycles="{num_cycles}">
        <Sequence>
          <SubTree ID="OppositionCycle"
                   hand_speed="{hand_speed}"
                   hand_max_vel="{hand_max_vel}"
                   use_home_return="{use_home_return}"/>
          <!-- 가속: speed × 1.42857 (≈ 1/0.7), 최대 hand_max_speed -->
          <Script code="hand_speed := hand_speed * 1.42857"/>
          <Fallback>
            <Precondition if="hand_speed &lt;= hand_max_speed" else="FAILURE">
              <AlwaysSuccess/>
            </Precondition>
            <Script code="hand_speed := hand_max_speed"/>
          </Fallback>
          <SetGains hand_trajectory_speed="{hand_speed}"/>
        </Sequence>
      </Repeat>

      <!-- ── Phase 3: 감속, home 경유 복원 ── -->
      <Script code="use_home_return := true"/>
      <Repeat num_cycles="{num_cycles}">
        <Sequence>
          <SubTree ID="OppositionCycle"
                   hand_speed="{hand_speed}"
                   hand_max_vel="{hand_max_vel}"
                   use_home_return="{use_home_return}"/>
          <!-- 감속: speed × 0.7, 최소 hand_init_speed -->
          <Script code="hand_speed := hand_speed * 0.7"/>
          <Fallback>
            <Precondition if="hand_speed >= hand_init_speed" else="FAILURE">
              <AlwaysSuccess/>
            </Precondition>
            <Script code="hand_speed := hand_init_speed"/>
          </Fallback>
          <SetGains hand_trajectory_speed="{hand_speed}"/>
        </Sequence>
      </Repeat>

      <!-- 기본 속도 복원 -->
      <SetGains hand_trajectory_speed="1.0"/>

    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- WaveDemo: Three-phase flex/extend wave with acceleration ramp       -->
  <!--   Exercises each finger joint (including per-joint articulation:    -->
  <!--   thumb_mcp, index_dip, middle_dip) in a sequential wave pattern.  -->
  <!--   Phase 1: Sequential wave with increasing speed (x1.43/cycle).    -->
  <!--   Phase 2: Simultaneous parallel wave at maximum speed.            -->
  <!--   Phase 3: Sequential wave with decreasing speed (x0.7/cycle).    -->
  <!--   All speed changes are applied via SetGains hand_trajectory_speed  -->
  <!--   to stay synchronized with the RT controller.                      -->
  <!-- ================================================================== -->
  <BehaviorTree ID="WaveDemo">
    <Sequence>

      <!-- 공통 변수 설정 (여기서 한 번만 변경하면 전체 적용) -->
      <Script code="num_cycles := 4; hand_init_speed := 0.7854; hand_max_speed := 3.1415; hand_max_vel := 6.2832"/>
      <Script code="hand_speed := hand_init_speed"/>

      <!-- ── Phase 1: 순차, 점점 빠르게 ── -->
      <SetGains hand_trajectory_speed="{hand_init_speed}"/>
      <Repeat num_cycles="{num_cycles}">
        <Sequence name="AcceleratingWave">
          <FlexExtendFinger finger_name="thumb_mcp"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="thumb"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="ring"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <!-- 가속: speed × 1.42857, 최대 hand_max_speed -->
          <Script code="hand_speed := hand_speed * 1.42857"/>
          <Fallback>
            <Precondition if="hand_speed &lt;= hand_max_speed" else="FAILURE">
              <AlwaysSuccess/>
            </Precondition>
            <Script code="hand_speed := hand_max_speed"/>
          </Fallback>
          <SetGains hand_trajectory_speed="{hand_speed}"/>
        </Sequence>
      </Repeat>

      <!-- ── Phase 2: 동시, 최고 속도 ── -->
      <Repeat num_cycles="{num_cycles}">
        <Parallel success_count="7" failure_count="1" name="SimultaneousFastWave">
          <FlexExtendFinger finger_name="thumb_mcp"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="thumb"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="ring"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
        </Parallel>
      </Repeat>

      <!-- ── Phase 3: 순차, 점점 느려짐 ── -->
      <Repeat num_cycles="{num_cycles}">
        <Sequence name="DeceleratingWave">
          <FlexExtendFinger finger_name="thumb_mcp"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="thumb"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="index"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle_dip"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="middle"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <FlexExtendFinger finger_name="ring"
                            hand_trajectory_speed="{hand_speed}"
                            hand_max_traj_velocity="{hand_max_vel}"/>
          <!-- 감속: speed × 0.7, 최소 hand_init_speed -->
          <Script code="hand_speed := hand_speed * 0.7"/>
          <Fallback>
            <Precondition if="hand_speed >= hand_init_speed" else="FAILURE">
              <AlwaysSuccess/>
            </Precondition>
            <Script code="hand_speed := hand_init_speed"/>
          </Fallback>
          <SetGains hand_trajectory_speed="{hand_speed}"/>
        </Sequence>
      </Repeat>

      <!-- 기본 속도 복원 -->
      <SetGains hand_trajectory_speed="1.0"/>

    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- FullDemo: Combined arm hold + hand demo                             -->
  <!--   Runs UR5eHoldPose (demo_pose) in parallel with the hand           -->
  <!--   sequence (OppositionDemo -> WaveDemo). The arm holds its pose     -->
  <!--   via Parallel until the hand sequence completes (success_count=1), -->
  <!--   then UR5eHoldPose is halted automatically.                        -->
  <!-- ================================================================== -->
  <BehaviorTree ID="FullDemo">
    <!-- success_count=1: Hand 시퀀스 완료 시 종료 (UR5e halt) -->
    <Parallel success_count="1" failure_count="1">
      <!-- UR5e: 데모 자세로 이동 후 모션 종료까지 대기 -->
      <UR5eHoldPose pose="demo_pose"/>

      <!-- Hand: Opposition → Wave 순차 실행 (각 SubTree 내부에서 공통 변수 설정) -->
      <Sequence name="HandDemoSequence">
        <SubTree ID="OppositionDemo"/>
        <SubTree ID="WaveDemo"/>
      </Sequence>
    </Parallel>
  </BehaviorTree>

</root>
