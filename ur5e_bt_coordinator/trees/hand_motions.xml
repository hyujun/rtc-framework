<!-- file: trees/hand_motions.xml -->
<!-- UR5e + 10-DoF Hand Demo: Opposition + FlexExtend Wave -->
<!-- BehaviorTree.CPP v4 syntax -->

<root BTCPP_format="4" main_tree_to_execute="FullDemo">

  <!-- ================================================================== -->
  <!-- SingleOpposition: 엄지 + 대상 손가락 opposition → 조건부 home 복귀   -->
  <!-- ================================================================== -->
  <BehaviorTree ID="SingleOpposition">
    <Sequence>
      <!-- 엄지와 대상 손가락을 동시에 opposition 포즈로 이동 -->
      <Parallel success_count="2" failure_count="1">
        <MoveFinger finger_name="thumb"            pose="{op_thumb_pose}"   duration="{op_duration}"/>
        <MoveFinger finger_name="{op_target_finger}" pose="{op_target_pose}" duration="{op_duration}"/>
      </Parallel>

      <!-- use_home_return == true 일 때만 home 포즈로 복귀 -->
      <Fallback>
        <Precondition if="use_home_return == false" else="FAILURE">
          <AlwaysSuccess/>
        </Precondition>
        <SetHandPose pose="home" duration="{op_duration}"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- OppositionDemo: 가감속 Opposition (Phase 1→2→3)                     -->
  <!-- ================================================================== -->
  <BehaviorTree ID="OppositionDemo">
    <Sequence>

      <!-- 초기값 설정 -->
      <Script code="op_duration := 1.5; use_home_return := true"/>

      <!-- ── Phase 1: 느리게, home 경유 (1회 순회) ── -->
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_index_oppose"
               op_target_finger="index"
               op_target_pose="index_oppose"
               op_duration="{op_duration}"
               use_home_return="{use_home_return}"/>
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_middle_oppose"
               op_target_finger="middle"
               op_target_pose="middle_oppose"
               op_duration="{op_duration}"
               use_home_return="{use_home_return}"/>
      <SubTree ID="SingleOpposition"
               op_thumb_pose="thumb_ring_oppose"
               op_target_finger="ring"
               op_target_pose="ring_oppose"
               op_duration="{op_duration}"
               use_home_return="{use_home_return}"/>

      <!-- ── Phase 2: 점점 빨라짐, home 생략 (3회 순회) ── -->
      <Script code="use_home_return := false"/>
      <Repeat num_cycles="3">
        <Sequence>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_index_oppose"
                   op_target_finger="index"
                   op_target_pose="index_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_middle_oppose"
                   op_target_finger="middle"
                   op_target_pose="middle_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_ring_oppose"
                   op_target_finger="ring"
                   op_target_pose="ring_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <!-- decay: 가속 (최소 0.3s 보장) -->
          <Script code="op_duration := max(op_duration * 0.7, 0.3)"/>
        </Sequence>
      </Repeat>

      <!-- ── Phase 3: 점점 느려짐, home 경유 복원 (3회 순회) ── -->
      <Script code="use_home_return := true"/>
      <Repeat num_cycles="3">
        <Sequence>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_index_oppose"
                   op_target_finger="index"
                   op_target_pose="index_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_middle_oppose"
                   op_target_finger="middle"
                   op_target_pose="middle_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <SubTree ID="SingleOpposition"
                   op_thumb_pose="thumb_ring_oppose"
                   op_target_finger="ring"
                   op_target_pose="ring_oppose"
                   op_duration="{op_duration}"
                   use_home_return="{use_home_return}"/>
          <!-- accel_factor (1/0.7 ≈ 1.4): 감속 (최대 1.5s 보장) -->
          <Script code="op_duration := min(op_duration * 1.4, 1.5)"/>
        </Sequence>
      </Repeat>

    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- WaveDemo: 가감속 Flexion/Extension Wave (Phase 1→2→3)               -->
  <!-- ================================================================== -->
  <BehaviorTree ID="WaveDemo">
    <Sequence>

      <!-- 초기값 설정 -->
      <Script code="wave_duration := 2.0"/>

      <!-- ── Phase 1: 순차, 점점 빠르게 (3회) ── -->
      <Repeat num_cycles="3">
        <Sequence name="AcceleratingWave">
          <FlexExtendFinger finger_name="thumb"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="index"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="middle" duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="ring"   duration="{wave_duration}"/>
          <!-- 가속 (최소 0.3s 보장) -->
          <Script code="wave_duration := max(wave_duration * 0.7, 0.3)"/>
        </Sequence>
      </Repeat>

      <!-- ── Phase 2: 동시, 최고 속도 (3회) ── -->
      <Repeat num_cycles="3">
        <Parallel success_count="4" failure_count="1" name="SimultaneousFastWave">
          <FlexExtendFinger finger_name="thumb"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="index"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="middle" duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="ring"   duration="{wave_duration}"/>
        </Parallel>
      </Repeat>

      <!-- ── Phase 3: 순차, 점점 느려짐 (3회) ── -->
      <Repeat num_cycles="3">
        <Sequence name="DeceleratingWave">
          <FlexExtendFinger finger_name="thumb"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="index"  duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="middle" duration="{wave_duration}"/>
          <FlexExtendFinger finger_name="ring"   duration="{wave_duration}"/>
          <!-- 감속 (최대 2.0s 보장) -->
          <Script code="wave_duration := min(wave_duration * 1.4, 2.0)"/>
        </Sequence>
      </Repeat>

    </Sequence>
  </BehaviorTree>

  <!-- ================================================================== -->
  <!-- FullDemo: UR5e 자세 유지 + Hand 데모 (Opposition → Wave)             -->
  <!-- ================================================================== -->
  <BehaviorTree ID="FullDemo">
    <!-- success_count=1: Hand 시퀀스 완료 시 종료 (UR5e halt) -->
    <Parallel success_count="1" failure_count="1">
      <!-- UR5e: 데모 자세 도달 후 영구 RUNNING -->
      <UR5eHoldPose pose="demo_pose"/>

      <!-- Hand: Opposition → Wave 순차 실행 -->
      <Sequence name="HandDemoSequence">
        <SubTree ID="OppositionDemo"/>
        <SubTree ID="WaveDemo"/>
      </Sequence>
    </Parallel>
  </BehaviorTree>

</root>
