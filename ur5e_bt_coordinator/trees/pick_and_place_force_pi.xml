<!-- file: trees/pick_and_place_force_pi.xml -->
<!-- UR5e + Hand Pick-and-Place demo (Force-PI adaptive grasp variant) -->
<!-- BehaviorTree.CPP v4 syntax -->
<!--
  Uses the controller-internal Force-PI state machine
  (Approaching -> Contact -> ForceControl -> Holding) instead of BT-side
  incremental finger closing.

  ─── Failure handling ─────────────────────────────────────────────────
  Top-level Fallback wraps the normal pick sequence with
  ForcePIEmergencyAbort. On any FAILURE the abort SubTree opens the hand
  via the FSM and retreats by {grasp_abort_retreat_z} from the current
  TCP pose. ForceFailure ensures the tree result remains FAILURE so the
  operator is informed of the unsuccessful run.

  Phase 6 (grasp) goes through ForcePIGraspWithRetry which retries
  ONLY the ForcePIGrasp call (not approach/descend). Each retry begins
  with an idempotent ForcePIRelease so a stuck FSM is forced back to
  kIdle before the next grasp_command=1.

  Phases 8/9 (transport, lower) include in-transit IsGrasped guards so
  drops between the lift and the place are caught instead of placing
  with an empty hand.

  ─── Shared blackboard variables (declared in bt_coordinator.yaml) ────
    {grasp_target_force_N}    : Force-PI target force [N]
    {grasp_verify_force_N}    : post-grasp / post-lift verification floor [N]
    {grasp_sustained_ms}      : sustained window for IsForceAbove [ms]
    {grasp_min_fingertips}    : minimum fingertips required
    {grasp_in_transit_min_N}  : transport/lower drop-guard threshold [N]
    {grasp_abort_retreat_z}   : EmergencyAbort retreat distance [m]
    {grasp_max_attempts}      : ForcePIGrasp retry count (1 = disabled)
    {grasp_retry_settle_s}    : retry inter-attempt settling [s]
    {tcp_rpy_offset_r/p/y}    : Phase 3 TCP RPY offset [rad] (all 0 = no-op)
    {tcp_rotation_mode}       : 'add' | 'quat_body' | 'quat_world'

  Prerequisite: place_pose must be set in Blackboard before tree starts.
  Prerequisite: grasp_controller_type: "force_pi" in demo controller YAML.
-->

<root BTCPP_format="4" main_tree_to_execute="ForcePIPickAndPlace">

  <include path="common_motions.xml"/>

  <BehaviorTree ID="ForcePIPickAndPlace">
    <Fallback name="main_with_safety">

      <Sequence name="normal_pick_and_place">

        <!-- ======================================================== -->
        <!-- Phase 1: Move to table_top joint pose                     -->
        <!-- ======================================================== -->
        <SwitchController controller_name="demo_joint_controller"
                          timeout_s="3.0"/>

        <SetGains
                  trajectory_speed="0.15"/>

        <MoveToJoints pose_name="table_top"
                      tolerance="0.01"
                      timeout_s="15.0"/>

        <!-- ======================================================== -->
        <!-- Phase 2: Detect object via vision                         -->
        <!-- ======================================================== -->
        <SubTree ID="DetectObject"
                 pose="{object_pose}"
                 num_attempts="10"
                 wait_s="0.5"/>

        <!-- ======================================================== -->
        <!-- Phase 3: Switch to task-space controller                  -->
        <!-- ======================================================== -->
        <SwitchController controller_name="demo_task_controller"
                          timeout_s="3.0"/>

        <!-- ======================================================== -->
        <!-- Phase 3.5: TCP re-orientation                             -->
        <!--   Read current TCP pose, apply RPY offset                 -->
        <!--   ({tcp_rpy_offset_r/p/y}, {tcp_rotation_mode}), and      -->
        <!--   move to that pose. Translation is preserved             -->
        <!--   (xyz come from the current pose, no offset).            -->
        <!--   All offsets = 0 -> MoveToPose to the same pose          -->
        <!--   succeeds immediately.                                   -->
        <!-- ======================================================== -->
        <GetCurrentPose pose="{phase3_current_pose}"/>
        <ComputeOffsetPose input_pose="{phase3_current_pose}"
                           offset_roll="{tcp_rpy_offset_r}"
                           offset_pitch="{tcp_rpy_offset_p}"
                           offset_yaw="{tcp_rpy_offset_y}"
                           rotation_mode="{tcp_rotation_mode}"
                           output_pose="{phase3_oriented_pose}"/>
        <SetGains
                  trajectory_speed="0.1"/>
        <MoveToPose target="{phase3_oriented_pose}"
                    position_tolerance="0.005"
                    orientation_tolerance="0.025"
                    timeout_s="5.0"/>

        <!-- ======================================================== -->
        <!-- Phase 4: Pre-open hand via Force-PI FSM                   -->
        <!--   Idempotent: Idle -> Idle no-op on a fresh controller,   -->
        <!--   drives Releasing -> Idle on a re-run.                   -->
        <!-- ======================================================== -->
        <SubTree ID="ForcePIRelease"
                 release_timeout_ms="5000"/>

        <SubTree ID="ApproachFromAbove"
                 target_pose="{object_pose}"
                 offset_z="0.04"
                 pos_tol="0.003"
                 ori_tol="0.05"
                 timeout_s="10.0"
                 approach_pose="{approach_pose}"/>

        <!-- ======================================================== -->
        <!-- Phase 5: Slow descend to object (kept outside retry)      -->
        <!-- ======================================================== -->
        <SubTree ID="SlowDescend"
                 target_pose="{object_pose}"
                 traj_speed="0.05"
                 pos_tol="0.002"
                 ori_tol="0.05"
                 timeout_s="8.0"
                 constant_z="{object_final_z}"/>

        <!-- ======================================================== -->
        <!-- Phase 6: Force-PI grasp with retry (hand-only)            -->
        <!--   Retries only the ForcePIGrasp call. Each iteration      -->
        <!--   resets the FSM via ForcePIRelease before re-issuing     -->
        <!--   grasp_command=1. Diagnostic logging on each failure.    -->
        <!-- ======================================================== -->
        <SubTree ID="ForcePIGraspWithRetry"
                 target_force_N="{grasp_target_force_N}"
                 grasp_timeout_ms="10000"
                 verify_force_N="{grasp_target_force_N}"
                 min_fingertips="{grasp_min_fingertips}"
                 sustained_ms="{grasp_sustained_ms}"
                 max_attempts="{grasp_max_attempts}"
                 retry_settle_s="{grasp_retry_settle_s}"/>

        <!-- ======================================================== -->
        <!-- Phase 7: Lift and verify holding                          -->
        <!-- ======================================================== -->
        <SubTree ID="LiftAndVerify"
                 base_pose="{object_pose}"
                 offset_z="0.12"
                 traj_speed="0.08"
                 pos_tol="0.005"
                 timeout_s="6.0"
                 verify_force_N="{grasp_verify_force_N}"
                 verify_min_tips="{grasp_min_fingertips}"
                 lift_pose="{lift_pose}"/>

        <!-- ======================================================== -->
        <!-- Phase 8: Transport to goal position (with in-transit      -->
        <!--   drop guard immediately after the move completes).       -->
        <!-- ======================================================== -->
        <SetGains
                  trajectory_speed="0.1"/>

        <MoveToPose target="{place_pose}"
                    position_tolerance="0.005"
                    timeout_s="12.0"/>

        <IsGrasped force_threshold_N="{grasp_in_transit_min_N}"
                   min_fingertips="{grasp_min_fingertips}"/>

        <!-- ======================================================== -->
        <!-- Phase 9: Lower to release height (with drop guard).       -->
        <!-- ======================================================== -->
        <ComputeOffsetPose input_pose="{place_pose}"
                           offset_z="-0.05"
                           output_pose="{lower_pose}"/>
        <SetGains
                  trajectory_speed="0.05"/>
        <MoveToPose target="{lower_pose}"
                    position_tolerance="0.003"
                    timeout_s="6.0"/>

        <IsGrasped force_threshold_N="{grasp_in_transit_min_N}"
                   min_fingertips="{grasp_min_fingertips}"/>

        <!-- ======================================================== -->
        <!-- Phase 10: Force-PI release and retreat                    -->
        <!-- ======================================================== -->
        <SubTree ID="ForcePIRelease"
                 release_timeout_ms="5000"/>

        <WaitDuration duration_s="0.3"/>

        <ComputeOffsetPose input_pose="{place_pose}"
                           offset_z="0.08"
                           output_pose="{retreat_pose}"/>
        <SetGains
                  trajectory_speed="0.1"/>
        <MoveToPose target="{retreat_pose}"
                    position_tolerance="0.005"
                    timeout_s="6.0"/>

        <!-- Restore original controller gains -->
        <SetGains/>

      </Sequence>

      <!-- ── Failure path: open hand + retreat, then propagate FAILURE -->
      <ForceFailure>
        <SubTree ID="ForcePIEmergencyAbort"
                 retreat_z="{grasp_abort_retreat_z}"/>
      </ForceFailure>

    </Fallback>
  </BehaviorTree>

</root>
