<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_bt_coordinator</name>
  <version>5.17.0</version>
  <description>BehaviorTree.CPP v4 task coordinator for UR5e + Hand system. 22 BT nodes (16 action, 6 condition), 6 tree XML files, 80 Hz non-RT tick loop.</description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>behaviortree_cpp</depend>
  <depend>std_msgs</depend>
  <depend>std_srvs</depend>
  <depend>geometry_msgs</depend>
  <depend>rtc_msgs</depend>
  <depend>shape_estimation_msgs</depend>
  <depend>eigen</depend>
  <build_depend>ament_index_cpp</build_depend>

  <test_depend>ament_cmake_gtest</test_depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
