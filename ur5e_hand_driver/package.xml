<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_hand_driver</name>
  <version>5.17.0</version>
  <description>Event-driven UDP driver for the 10-DOF custom hand (44 tactile sensors): request-response polling with SeqLock state, Bessel-filtered sensor decimation, and ONNX-based fingertip F/T inference.</description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>rtc_base</depend>
  <depend>rtc_communication</depend>
  <depend>rtc_inference</depend>
  <depend>rtc_msgs</depend>
  <depend>ament_index_cpp</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
