<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_hand_status_monitor</name>
  <version>5.17.0</version>
  <description>
    UR5e + Hand status monitor — extends RtcStatusMonitor with hand device
    monitoring (motor/sensor data quality, message rate, timeout detection).
  </description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>rtc_base</depend>
  <depend>rtc_status_monitor</depend>
  <depend>rtc_msgs</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
