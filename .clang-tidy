---
# RTC Framework clang-tidy config.
#
# 현재 사용처 (2026-05-01):
#   - clangd `--clang-tidy` (IDE 편집 시 squiggle) — 주요 사용처
#   - CI clang-tidy job 은 PR #93 에서 제거됨. 별도 PR 에서 복원 예정 (코드 차단력
#     없음 — `WarningsAsErrors` 는 CI 가 다시 도입되는 시점에 효력 발생)
#   - 빌드 통합 (`CMAKE_CXX_CLANG_TIDY`) 은 의도적으로 미설정 — 빌드 시간 30~50%
#     증가. RT 개발 iteration 우선
#
# IDE-only 환경에서도 가치 있는 부분:
#   - readability-identifier-naming.* — conventions.md "Naming" 의 유일한
#     기계 검증 경로 (k-prefix constants, snake_case_ members, CamelCase types)
#   - 비활성 check 목록 — clangd squiggle 노이즈 억제
#
# WarningsAsErrors 는 §3 invariants 와 정렬:
#   - bugprone-exception-escape : RT-2 (RT path throw 금지)
#   - performance-*             : RT path 성능 회귀 차단
#
# 그룹 비활성:
#   - cppcoreguidelines-pro-*   : Eigen/포인터 산술/캐스트 — ROS 2 + 수치코드와 충돌
#
# 노이즈 큰 개별 check 비활성:
#   - cert-err58-cpp            : ROS 2 static node/macro 패턴
#   - misc-non-private-member-variables-in-classes : POD 구조체 다수
#   - modernize-use-{auto,trailing-return-type,pass-by-value}, modernize-return-braced-init-list
#                               : 스타일 — Google C++ + RT-5 (auto+Eigen 금지) 와 정렬
#   - performance-unnecessary-value-param : Eigen 작은 객체 by-value 가 더 빠른 경우 다수
#   - readability-{magic-numbers, implicit-bool-conversion, named-parameter,
#                  braces-around-statements, redundant-smartptr-get,
#                  simplify-boolean-expr, convert-member-functions-to-static}
#                               : ROS 2 코드 노이즈
#   - google-{build-using-namespace, explicit-constructor, readability-braces-around-statements,
#             readability-casting, readability-todo, runtime-int, runtime-references}
#                               : Google style 의 일부 — RTC convention 우선
Checks: "-*,
  bugprone-*,
  cert-*,
  cppcoreguidelines-*,
  google-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  -cppcoreguidelines-pro-*,
  -cert-err58-cpp,
  -google-build-using-namespace,
  -google-explicit-constructor,
  -google-readability-braces-around-statements,
  -google-readability-casting,
  -google-readability-todo,
  -google-runtime-int,
  -google-runtime-references,
  -misc-non-private-member-variables-in-classes,
  -modernize-pass-by-value,
  -modernize-return-braced-init-list,
  -modernize-use-auto,
  -modernize-use-trailing-return-type,
  -performance-unnecessary-value-param,
  -readability-braces-around-statements,
  -readability-convert-member-functions-to-static,
  -readability-implicit-bool-conversion,
  -readability-magic-numbers,
  -readability-named-parameter,
  -readability-redundant-smartptr-get,
  -readability-simplify-boolean-expr"
HeaderFilterRegex: '^(?!.*\b(build|install|log|_deps)\b).*$'
WarningsAsErrors: 'bugprone-exception-escape,performance-*'
CheckOptions:
  # Google C++ Style + CLAUDE.md naming (see "Code Conventions").
  # 신규/변경 코드부터 점진 적용 — 기존 위반은 HeaderFilterRegex / NOLINT 로 단계적 전환.
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.MethodCase
    value: CamelCase
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _
  - key: readability-identifier-naming.ProtectedMemberCase
    value: lower_case
  - key: readability-identifier-naming.ProtectedMemberSuffix
    value: _
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariablePrefix
    value: k
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: k
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantPrefix
    value: k
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
...
