<?xml version='1.0' encoding='utf-8'?>
<mujoco model="iiwa7_with_leap_right">
  <compiler angle="radian" meshdir="../meshes/visual" autolimits="true" />
  <!-- timestep/iterations/ls_iterations 등 solver 파라미터는 mujoco_simulator.yaml에서
       관리한다 (rtc_mujoco_sim ApplySolverConfig가 scene_*.xml에서만 <option>을 탐지하므로
       자식 모델의 <option>은 어차피 YAML로 덮어씌워짐). -->
  <option integrator="implicitfast" />

  <!-- ─── default classes (joint properties + position-servo PD SSoT) ─────────
       iiwa7: Panda 유사 class. proximal(J1-J4)이 큰 link 관성/토크 → 상향.
              PD gain은 ur5e MJCF 패턴(size3 kp=2000/kd=400, size1 kp=500/kd=100,
              ζ≈0.2)을 따르되 iiwa7 payload에 맞춰 1.5× 스케일:
                proximal kp=3000 kd=600, distal kp=750 kd=150.
       LEAP : XC430 gear 159.5:1, 고감속비 → reflected inertia 큼.
              MCP(flex) / PIP(abduction at base) / DIP(mid+tip) / thumb 4-tier.
              PD gain은 forcerange ±0.95 N·m 한계 하에서 보수적으로 kp=2.5 kd=0.125
              (이전 값의 1/4). forcerange는 XC430 stall 안전 한계 ±0.95로 유지.
       MANUAL: urdf_to_mjcf 재실행 시 이 블록 + 각 joint/actuator의 class 속성이
               사라집니다. 재주입할 것 (robots/iiwa7_leap/README.md). -->
  <default>
    <default class="iiwa7">
      <joint armature="0.2" damping="2.0" frictionloss="0.3" />
      <general gaintype="fixed" biastype="affine" forcerange="-200 200" />
      <default class="iiwa7_proximal">
        <joint armature="0.25" damping="3.0" frictionloss="0.5" />
        <general gainprm="3000" biasprm="0 -3000 -600" />
      </default>
      <default class="iiwa7_distal">
        <joint armature="0.15" damping="1.0" frictionloss="0.2" />
        <general gainprm="750" biasprm="0 -750 -150" />
      </default>
    </default>
    <default class="leap">
      <general gaintype="fixed" biastype="affine" gainprm="2.5"
               biasprm="0 -2.5 -0.125" forcerange="-0.95 0.95" />
      <default class="leap_mcp">
        <joint armature="0.006" damping="0.10" frictionloss="0.04" />
      </default>
      <default class="leap_pip">
        <joint armature="0.004" damping="0.06" frictionloss="0.025" />
      </default>
      <default class="leap_dip">
        <joint armature="0.003" damping="0.04" frictionloss="0.015" />
      </default>
      <default class="leap_thumb">
        <joint armature="0.006" damping="0.10" frictionloss="0.04" />
      </default>
    </default>
  </default>

