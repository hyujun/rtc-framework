<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_bringup</name>
  <version>0.1.0</version>
  <description>UR5e-specific bringup: demo controllers, launch files, and robot configuration.</description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>rtc_controller_manager</depend>
  <depend>rtc_controller_interface</depend>
  <depend>rtc_controllers</depend>
  <depend>rtc_scripts</depend>
  <depend>rtc_mujoco_sim</depend>
  <depend>rtc_digital_twin</depend>
  <depend>ur5e_hand_driver</depend>
  <depend>ur5e_description</depend>
  <depend>yaml-cpp</depend>

  <build_depend>pinocchio</build_depend>
  <build_depend>eigen</build_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
