<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_bringup</name>
  <version>5.17.0</version>
  <description>UR5e-specific launch files, YAML configs, and demo controllers (DemoJointController, DemoTaskController) for RTC framework. Includes robot/sim launch, GUI tools, and CPU affinity setup.</description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>
  <buildtool_depend>ament_cmake</buildtool_depend>
  <depend>ament_index_cpp</depend>
  <depend>rclcpp</depend>
  <depend>rtc_controller_interface</depend>
  <depend>rtc_controllers</depend>
  <depend>rtc_base</depend>
  <depend>rtc_msgs</depend>
  <depend>pinocchio</depend>
  <depend>rtc_urdf_bridge</depend>
  <depend>yaml-cpp</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>rtc_controller_manager</depend>
  <exec_depend>rclpy</exec_depend>
  <exec_depend>python3-pyqt5</exec_depend>
  <exec_depend>rtc_scripts</exec_depend>
  <exec_depend>ur5e_description</exec_depend>
  <exec_depend>ur5e_hand_driver</exec_depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_cmake_gtest</test_depend>
  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
