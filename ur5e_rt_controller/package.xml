<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ur5e_rt_controller</name>
  <version>5.16.0</version>
  <description>UR5e 500 Hz real-time position/torque controller with P, JointPD, CLIK, OSC, and Hand controller implementations. clock_nanosleep RT loop + SPSC publish offload architecture.</description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>pinocchio</depend>
  <depend>ur5e_rt_base</depend>
  <depend>ur5e_hand_udp</depend>
  <depend>ur5e_status_monitor</depend>
  <depend>ament_index_cpp</depend>
  <depend>yaml-cpp</depend>
  <depend>ur5e_msgs</depend>

  <exec_depend>ur5e_description</exec_depend>

  <test_depend>ament_cmake_gtest</test_depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
