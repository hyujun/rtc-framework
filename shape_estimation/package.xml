<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>shape_estimation</name>
  <version>5.17.0</version>
  <description>
    ToF-based object shape estimation for UR5e + custom hand system.
    Estimates shape primitives (sphere, cylinder, plane, box) from
    fingertip ToF sensor readings using voxel-based point cloud
    accumulation and least-squares primitive fitting.
  </description>
  <maintainer email="jeryblueput@gmail.com">Junho Park</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>std_srvs</depend>
  <depend>sensor_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>visualization_msgs</depend>
  <depend>shape_estimation_msgs</depend>
  <depend>rclcpp_action</depend>
  <depend>rtc_msgs</depend>

  <build_depend>eigen</build_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
